    "lines":  [
                  {
                      "line_number":  2122,
                      "text":  "- Oh man.",
                      "start":  5014,
                      "label":  "fluff"
                  },
                  {
                      "line_number":  2123,
                      "text":  "Y\u0027all know how hard it is to drive Uber",
                      "start":  5015,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2124,
                      "text":  "when you\u0027re a big black dude named Courtney?",
                      "start":  5017,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2126,
                      "text":  "People don\u0027t believe it\u0027s my car.",
                      "start":  5022,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2127,
                      "text":  "I had a lady once go, are you sure this is your car?",
                      "start":  5023,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2129,
                      "text":  "You know, you hear a joke and you think she\u0027s playing,",
                      "start":  5028,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2130,
                      "text":  "but she\u0027s like.",
                      "start":  5030,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2132,
                      "text":  "And because I\u0027m a comic, I\u0027m all like,",
                      "start":  5032,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2133,
                      "text":  "no, we stole this motherfucker together, let\u0027s go!",
                      "start":  5034,
                      "label":  "punchline"
                  },
                  {
                      "line_number":  2135,
                      "text":  "Happy Black History Month, by the way.",
                      "start":  5040,
                      "label":  "tag"
                  },
                  {
                      "line_number":  2137,
                      "text":  "All right, so anyways, I\u0027m recently",
                      "start":  5044,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2138,
                      "text":  "taking a tolerance break from weed.",
                      "start":  5046,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2139,
                      "text":  "I don\u0027t hate weed.",
                      "start":  5050,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2140,
                      "text":  "I just don\u0027t like the things that I do when I\u0027m on it.",
                      "start":  5051,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2141,
                      "text":  "Like I\u0027ll go to my son\u0027s basketball game",
                      "start":  5053,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2142,
                      "text":  "and cheer for the wrong team.",
                      "start":  5054,
                      "label":  "punchline"
                  },
                  {
                      "line_number":  2144,
                      "text":  "I also do stupid things like forget I\u0027m driving Uber.",
                      "start":  5063,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2146,
                      "text":  "Have a passenger in the backseat just terrified.",
                      "start":  5070,
                      "label":  "setup"
                  },
                  {
                      "line_number":  2147,
                      "text":  "I\u0027m like, I\u0027m about to have a roommate.",
                      "start":  5074,
                      "label":  "punchline"
                  },
                  {
                      "line_number":  2149,
                      "text":  "I think that\u0027s about it y\u0027all, thank you.",
                      "start":  5078,
                      "label":  "fluff"
                  }
              ]
}
