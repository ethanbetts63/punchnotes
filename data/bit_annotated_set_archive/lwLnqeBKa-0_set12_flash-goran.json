    {"text": "would be, what else?", "label": "punchline", "bit": 1, "beat": 2, "line_number": 2448, "start": 5670},
    {"text": "I want to know.", "label": "tag", "bit": 1, "beat": 2, "line_number": 2449, "start": 5676},
    {"text": "I'm going to get my Glock out and take some notes.", "label": "tag", "bit": 1, "beat": 2, "line_number": 2450, "start": 5679},
    {"text": "Glock also makes pens.", "label": "tag", "bit": 1, "beat": 2, "line_number": 2451, "start": 5683},
    {"text": "Not everyone knows that.", "label": "tag", "bit": 1, "beat": 2, "line_number": 2452, "start": 5684},
    {"text": "I'm not the best representative from Bosnians.", "label": "setup", "bit": 1, "beat": 3, "line_number": 2453, "start": 5687},
    {"text": "I know that I forgot most of the language.", "label": "setup", "bit": 1, "beat": 3, "line_number": 2454, "start": 5691},
    {"text": "And I'm a good driver.", "label": "punchline", "bit": 1, "beat": 3, "line_number": 2455, "start": 5694},
