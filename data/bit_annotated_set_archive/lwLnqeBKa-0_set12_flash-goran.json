  "lines": [
    {"text": "How's it going, everybody?", "label": "fluff", "bit": null, "beat": null, "line_number": 2436, "start": 5634},
    {"text": "My name is Flash Goren.", "label": "fluff", "bit": null, "beat": null, "line_number": 2437, "start": 5637},
    {"text": "I'm Bosnian.", "label": "setup", "bit": 1, "beat": 1, "line_number": 2438, "start": 5639},
    {"text": "And I don't know what that means either.", "label": "punchline", "bit": 1, "beat": 1, "line_number": 2439, "start": 5640},
    {"text": "Yeah, I don't even know my own stereotypes,", "label": "setup", "bit": 1, "beat": 1, "line_number": 2440, "start": 5644},
    {"text": "which is kind of weird.", "label": "setup", "bit": 1, "beat": 1, "line_number": 2441, "start": 5647},
    {"text": "All I know is that other Europeans get very nervous", "label": "setup", "bit": 1, "beat": 1, "line_number": 2442, "start": 5649},
    {"text": "when I'm around them.", "label": "punchline", "bit": 1, "beat": 1, "line_number": 2443, "start": 5653},
    {"text": "And-- and you're welcome.", "label": "tag", "bit": 1, "beat": 1, "line_number": 2444, "start": 5656},
    {"text": "That's all I have to say about that.", "label": "fluff", "bit": 1, "beat": 1, "line_number": 2445, "start": 5663},
    {"text": "If somebody came up to me and said,", "label": "setup", "bit": 1, "beat": 2, "line_number": 2446, "start": 5666},
