                      "label":  "setup"
                  },
                  {
                      "line_number":  1118,
                      "text":  "autistic.",
                      "start":  2710,
                      "label":  "setup"
                  },
                  {
                      "line_number":  1119,
                      "text":  "And I don\u0027t think it\u0027s very nice.",
                      "start":  2711,
                      "label":  "setup"
                  },
                  {
                      "line_number":  1120,
                      "text":  "90% of the people I meet think I\u0027m autistic.",
                      "start":  2713,
                      "label":  "setup"
                  },
                  {
                      "line_number":  1121,
                      "text":  "The other 10% just don\u0027t talk to me.",
                      "start":  2716,
                      "label":  "punchline"
                  },
                  {
                      "line_number":  1122,
                      "text":  "I\u0027m very scared to be here tonight, but I\u0027m very proud to be Latino.",
                      "start":  2719,
                      "label":  "fluff"
                  },
                  {
                      "line_number":  1123,
                      "text":  "How many of you here in the audience?",
                      "start":  2722,
                      "label":  "fluff"
                  },
                  {
                      "line_number":  1124,
                      "text":  "It\u0027s fucking Texas.",
                      "start":  2723,
                      "label":  "fluff"
                  },
                  {
                      "line_number":  1125,
                      "text":  "Let me hear it.",
                      "start":  2724,
                      "label":  "fluff"
                  },
                  {
                      "line_number":  1127,
                      "text":  "Arriba!",
                      "start":  2726,
                      "label":  "fluff"
                  },
                  {
                      "line_number":  1128,
                      "text":  "Yeah, gracias.",
                      "start":  2727,
                      "label":  "fluff"
                  },
                  {
                      "line_number":  1130,
                      "text":  "I grew up for the longest time not knowing dogs got bigger than puppies.",
                      "start":  2729,
                      "label":  "setup"
                  },
                  {
