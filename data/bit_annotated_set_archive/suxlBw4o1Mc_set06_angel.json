    "lines":  [
                  {
                      "line_number":  1115,
                      "text":  "Hi there, folks.",
                      "start":  2705,
                      "label":  "fluff"
                  },
                  {
                      "line_number":  1116,
                      "text":  "My name\u0027s Angel.",
                      "start":  2707,
                      "label":  "fluff"
                  },
                  {
                      "line_number":  1117,
                      "text":  "People in the street approach me, and they call me",
