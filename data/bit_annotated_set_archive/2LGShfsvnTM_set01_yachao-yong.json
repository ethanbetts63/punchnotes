  "lines": [
    {"line_number": 111, "text": "My name's Yang.", "start": 402, "label": "fluff", "bit": null, "beat": null},
    {"line_number": 112, "text": "A fun fact about me, I was adopted by a few white guys.", "start": 403, "label": "setup", "bit": 1, "beat": 1},
    {"line_number": 113, "text": "Ever since I came to the United States at the age of 20.", "start": 411, "label": "setup", "bit": 1, "beat": 1},
    {"line_number": 115, "text": "Most comedians call themselves comics.", "start": 425, "label": "setup", "bit": 1, "beat": 1},
    {"line_number": 116, "text": "I just get called a commie.", "start": 428, "label": "punchline", "bit": 1, "beat": 1},
    {"line_number": 118, "text": "As an immigrant, the first question people ask me", "start": 434, "label": "setup", "bit": 2, "beat": 1},
    {"line_number": 119, "text": "is always, \"Hey, are you here by yourself?", "start": 437, "label": "setup", "bit": 2, "beat": 1},
    {"line_number": 120, "text": "\"Do you have family here?\"", "start": 439, "label": "setup", "bit": 2, "beat": 1},
    {"line_number": 121, "text": "And when I tell them, \"No, I don't have family here,\"", "start": 441, "label": "setup", "bit": 2, "beat": 1},
    {"line_number": 122, "text": "they always pity me.", "start": 444, "label": "setup", "bit": 2, "beat": 1},
    {"line_number": 123, "text": "They say, \"Oh, I'm sorry.", "start": 445, "label": "setup", "bit": 2, "beat": 1},
    {"line_number": 124, "text": "\"You're here alone?\"", "start": 446, "label": "setup", "bit": 2, "beat": 1},
    {"line_number": 125, "text": "I mean, yeah, that's exactly why I'm here.", "start": 448, "label": "punchline", "bit": 2, "beat": 1},
    {"line_number": 127, "text": "You think I flew 13 hours all the way across the world", "start": 452, "label": "tag", "bit": 2, "beat": 1},
    {"line_number": 128, "text": "I can see them again.", "start": 456, "label": "tag", "bit": 2, "beat": 1},
    {"line_number": 129, "text": "I'm here to get away from them.", "start": 459, "label": "tag", "bit": 2, "beat": 1},
    {"line_number": 130, "text": "Hello, America.", "start": 462, "label": "fluff", "bit": null, "beat": null},
    {"line_number": 131, "text": "Thank you.", "start": 464, "label": "fluff", "bit": null, "beat": null}
