  "lines": [
    {
      "text": "So guys, I'm Keaton.",
      "start": 5838,
      "label": "fluff",
      "line_number": 2621
    },
    {
      "text": "I'm from a military family.",
      "start": 5839,
      "label": "setup",
      "line_number": 2622
    },
    {
      "text": "I'm very proud of that.",
      "start": 5841,
      "label": "setup",
      "line_number": 2623
    },
    {
      "text": "My cousin is actually overseas right now.",
